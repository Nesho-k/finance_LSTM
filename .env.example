# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=info

# CORS (comma-separated origins)
# En développement: localhost
# En production: votre URL Vercel
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://meteo-front-one.vercel.app/

# Cache
CACHE_EXPIRE_HOURS=24
